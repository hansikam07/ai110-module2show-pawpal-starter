classDiagram
    class Owner {
        +str name
        +List~Pet~ pets
        +add_pet(pet Pet) void
        +get_all_tasks() List~tuple~Pet,Task~~
    }

    class Pet {
        +str name
        +str species
        +List~Task~ tasks
        +add_task(task Task) void
    }

    class Task {
        +str description
        +time time
        +int duration
        +int priority
        +Frequency frequency
        +bool completed
        +mark_complete() void
    }

    class Frequency {
        <<enumeration>>
        DAILY
        WEEKLY
        MONTHLY
    }

    class Scheduler {
        +Owner|List~Task~ source
        +List~Task~ _plan
        +generate_plan() List~Task~
        +explain_reasoning() str
    }

    Owner "1" o-- "*" Pet : has
    Pet "1" *-- "*" Task : has
    Task ..> Frequency : uses
    Scheduler ..> Owner : uses
    Scheduler ..> Task : schedules
