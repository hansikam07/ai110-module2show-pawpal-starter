classDiagram
    class Owner {
        +str name
        +List~Pet~ pets
        +add_pet(pet Pet) void
        +get_all_tasks() List~Task~
    }

    class Pet {
        +str name
        +str species
        +List~Task~ tasks
        +add_task(task Task) void
    }

    class Task {
        +str description
        +str time
        +int duration
        +int priority
        +str frequency
        +bool completed
        +mark_complete() void
    }

    class Scheduler {
        +Owner owner
        +generate_plan() List~Task~
        +explain_reasoning() str
    }

    Owner "1" o-- "*" Pet : has
    Pet "1" *-- "*" Task : has
    Scheduler ..> Owner : uses
